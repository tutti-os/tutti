{
  "schemaVersion": "tutti.agent.manifest.v2",
  "agentKey": "kimi-code",
  "version": "1.0.1",
  "name": "Kimi Code",
  "description": "Kimi Code through the standard Agent Client Protocol",
  "icon": {
    "type": "asset",
    "src": "assets/icon.png"
  },
  "maskIcon": {
    "type": "asset",
    "src": "assets/mask-icon.png"
  },
  "heroImage": {
    "type": "asset",
    "src": "assets/hero-image.jpg"
  },
  "runtime": {
    "kind": "standard-acp",
    "install": {
      "runner": "uv",
      "args": ["tool", "install", "kimi-cli==1.49.0"]
    },
    "launch": {
      "executable": "${installRoot}/bin/kimi",
      "args": ["acp"]
    }
  },
  "profiles": {
    "discovery": "profiles/discovery.json",
    "tools": "profiles/tools.json",
    "capabilities": "profiles/capabilities.json",
    "composer": "profiles/composer.json"
  },
  "localizationInfo": {
    "defaultLocale": "en",
    "defaultFile": "locales/en.json",
    "additionalLocales": [
      {
        "locale": "zh-CN",
        "file": "locales/zh-CN.json"
      }
    ]
  }
}
