{
  "extends": "../../configs/tsconfig/base.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "paths": {
      "@tutti-os/workspace-file-manager": [
        "../../workspace/file-manager/src/index.ts"
      ],
      "@tutti-os/workspace-file-manager/services": [
        "../../workspace/file-manager/src/services/index.ts"
      ],
      "@tutti-os/workbench-surface": ["../../workbench/surface/src/index.ts"],
      "@tutti-os/workspace-external-core/contracts": [
        "../../workspace/external-core/src/contracts/index.ts"
      ]
    },
    "types": ["node", "react", "react-dom", "vite/client"]
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts", "tsup.config.ts"]
}
