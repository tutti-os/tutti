{
  "name": "@tutti-os/browser-node",
  "version": "0.0.196",
  "private": false,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./assets/workspace-dock-website.png": {
      "types": "./src/assets/workspace-dock-website.d.ts",
      "default": "./src/assets/workspace-dock-website.png"
    },
    "./bridge": "./src/bridge/index.ts",
    "./chrome-cookie-import/macos": "./src/chrome-cookie-import/macos/index.ts",
    "./electron-main": "./src/electron-main/index.ts",
    "./electron-preload": "./src/electron-preload/index.ts",
    "./electron-renderer": "./src/electron-renderer/index.ts",
    "./i18n": "./src/i18n/index.ts",
    "./react": "./src/react/index.ts",
    "./workbench": "./src/workbench/index.ts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tutti-os/tutti.git",
    "directory": "packages/browser/workbench-node"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && node ../../../tools/scripts/copy-package-assets.mjs src/assets dist/assets && pnpm verify:built-entries",
    "test": "node --test --experimental-strip-types \"./src/**/*.test.ts\"",
    "typecheck": "node ../../../tools/scripts/run-tsgo-typecheck.mjs",
    "verify:built-entries": "node -e \"import('./dist/chrome-cookie-import/macos/index.js')\""
  },
  "dependencies": {
    "@tutti-os/ui-i18n-runtime": "0.0.196",
    "@tutti-os/ui-react-hooks": "0.0.196",
    "@tutti-os/ui-system": "0.0.196",
    "@tutti-os/workbench-surface": "0.0.196",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tutti-os/config-tsconfig": "workspace:*",
    "@types/node": "^24.0.1",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/ws": "^8.18.1",
    "electron": "^35.7.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "electron": "^35.7.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    }
  },
  "tutti": {
    "tailwindSourceRoot": "src"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./assets/workspace-dock-website.png": {
        "types": "./dist/assets/workspace-dock-website.d.ts",
        "default": "./dist/assets/workspace-dock-website.png"
      },
      "./bridge": {
        "types": "./dist/bridge/index.d.ts",
        "import": "./dist/bridge/index.js"
      },
      "./chrome-cookie-import/macos": {
        "types": "./dist/chrome-cookie-import/macos/index.d.ts",
        "import": "./dist/chrome-cookie-import/macos/index.js"
      },
      "./electron-main": {
        "types": "./dist/electron-main/index.d.ts",
        "import": "./dist/electron-main/index.js"
      },
      "./electron-preload": {
        "types": "./dist/electron-preload/index.d.ts",
        "import": "./dist/electron-preload/index.js"
      },
      "./electron-renderer": {
        "types": "./dist/electron-renderer/index.d.ts",
        "import": "./dist/electron-renderer/index.js"
      },
      "./i18n": {
        "types": "./dist/i18n/index.d.ts",
        "import": "./dist/i18n/index.js"
      },
      "./react": {
        "types": "./dist/react/index.d.ts",
        "import": "./dist/react/index.js"
      },
      "./workbench": {
        "types": "./dist/workbench/index.d.ts",
        "import": "./dist/workbench/index.js"
      }
    },
    "types": "./dist/index.d.ts"
  }
}
