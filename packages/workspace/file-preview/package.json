{
  "name": "@tutti-os/workspace-file-preview",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./core": "./src/core/index.ts",
    "./react": "./src/react/index.ts",
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tutti-os/tutti.git",
    "directory": "packages/workspace/file-preview"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && node ../../../tools/scripts/build-package-tailwind-css.mjs",
    "test": "node --test --experimental-strip-types \"./src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@tutti-os/config-tsconfig": "workspace:*",
    "@types/node": "^24.0.1",
    "@types/react": "^19.1.6",
    "react": "^19.1.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": "^19.1.0"
  },
  "tutti": {
    "tailwindSourceRoot": "src"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./core": {
        "types": "./dist/core/index.d.ts",
        "import": "./dist/core/index.js"
      },
      "./react": {
        "types": "./dist/react/index.d.ts",
        "import": "./dist/react/index.js"
      },
      "./styles.css": "./dist/styles.css"
    },
    "types": "./dist/index.d.ts"
  },
  "sideEffects": [
    "./src/styles.css",
    "./dist/styles.css"
  ]
}
