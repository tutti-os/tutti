{
  "name": "@tutti-os/mobile",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "android": "pnpm android:aar && react-native run-android",
    "android:aar": "make -C ../../packages/device-link android-aar",
    "build:android": "pnpm android:aar && cd android && ./gradlew app:assembleDebug",
    "check": "pnpm typecheck && pnpm test",
    "start": "react-native start",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tutti-os/agent-gui": "workspace:*",
    "@tutti-os/auth-bridge": "workspace:*",
    "@tutti-os/client-tuttid-ts": "workspace:*",
    "react": "19.2.6",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "5.6.2"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.0",
    "@babel/runtime": "7.29.2",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/codegen": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/gradle-plugin": "0.86.0",
    "@react-native/jest-preset": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@types/jest": "29.5.14",
    "@types/react": "19.2.15",
    "@types/react-test-renderer": "19.1.0",
    "jest": "29.7.0",
    "react-test-renderer": "19.2.6",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=24"
  }
}
