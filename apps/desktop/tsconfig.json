{
  "extends": "../../packages/configs/tsconfig/base.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "types": ["node", "vite/client"],
    "paths": {
      "@app/renderer/*": ["../../packages/agent/gui/app/renderer/*"],
      "@contexts/*": ["../../packages/agent/gui/contexts/*"],
      "@main/*": ["./src/main/*"],
      "@tutti-os/workspace-app-center": [
        "../../packages/workspace/app-center/src/index.ts"
      ],
      "@tutti-os/workspace-app-center/contracts": [
        "../../packages/workspace/app-center/src/contracts/index.ts"
      ],
      "@tutti-os/workspace-app-center/core": [
        "../../packages/workspace/app-center/src/core/index.ts"
      ],
      "@tutti-os/workspace-app-center/i18n": [
        "../../packages/workspace/app-center/src/i18n/index.ts"
      ],
      "@tutti-os/workspace-app-center/ui": [
        "../../packages/workspace/app-center/src/ui/index.ts"
      ],
      "@tutti-os/workspace-external-core": [
        "../../packages/workspace/external-core/src/index.ts"
      ],
      "@tutti-os/workspace-external-core/contracts": [
        "../../packages/workspace/external-core/src/contracts/index.ts"
      ],
      "@tutti-os/workspace-external-core/core": [
        "../../packages/workspace/external-core/src/core/index.ts"
      ],
      "@tutti-os/workspace-file-manager": [
        "../../packages/workspace/file-manager/src/index.ts"
      ],
      "@tutti-os/workspace-file-manager/i18n": [
        "../../packages/workspace/file-manager/src/i18n/index.ts"
      ],
      "@tutti-os/workspace-file-manager/services": [
        "../../packages/workspace/file-manager/src/services/index.ts"
      ],
      "@tutti-os/workspace-user-project": [
        "../../packages/workspace/user-project/src/index.ts"
      ],
      "@tutti-os/workspace-user-project/contracts": [
        "../../packages/workspace/user-project/src/contracts/index.ts"
      ],
      "@tutti-os/workspace-user-project/core": [
        "../../packages/workspace/user-project/src/core/index.ts"
      ],
      "@tutti-os/workspace-user-project/i18n": [
        "../../packages/workspace/user-project/src/i18n/index.ts"
      ],
      "@tutti-os/workspace-user-project/ui": [
        "../../packages/workspace/user-project/src/ui/index.ts"
      ],
      "@preload/*": ["./src/preload/*"],
      "@renderer/*": ["./src/renderer/src/*"],
      "@shared/contracts/dto": [
        "../../packages/agent/gui/shared/contracts/dto/index.ts"
      ],
      "@shared/contracts/dto/*": [
        "../../packages/agent/gui/shared/contracts/dto/*"
      ],
      "@shared/errors/appError": [
        "../../packages/agent/gui/shared/errors/appError.ts"
      ],
      "@shared/featureFlags/*": [
        "../../packages/agent/gui/shared/featureFlags/*"
      ],
      "@shared/types/*": ["../../packages/agent/gui/shared/types/*"],
      "@shared/utils/*": ["../../packages/agent/gui/shared/utils/*"],
      "@shared/*": ["./src/shared/*"]
    }
  },
  "include": ["electron.vite.config.ts", "src/**/*"]
}
