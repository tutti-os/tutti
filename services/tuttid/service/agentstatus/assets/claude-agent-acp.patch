+        return null;
+    }
+    let latest = null;
+    for (const line of transcript.trimEnd().split("\n")) {
+        if (!line) {
+            continue;
+        }
+        try {
+            const entry = JSON.parse(line);
+            latest = tuttiClaudeGoalStatusUpdate(entry.message ?? entry) ?? latest;
+        } catch {
+            continue;
+        }
+    }
+    return latest;
+}
